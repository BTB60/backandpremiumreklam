# /etc/premiumreklam/backend.env — chmod 600 root:root və ya premiumreklam oxuya bilməsi üçün qrup
# sudo install -o root -g premiumreklam -m 640 ...

SPRING_PROFILES_ACTIVE=production
PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/premium_reklam
SPRING_DATASOURCE_USERNAME=premium_user
SPRING_DATASOURCE_PASSWORD=DEGISTIR_GUICLU_PAROL

JWT_SECRET=DEGISTIR_MINIMUM_64_SIMVOL_UZUN_RANDOM_STRING
JWT_EXPIRATION=86400000

LOG_LEVEL=INFO
DDL_AUTO=update

# Nginx arxasında HTTPS düzgün tanınsın
SERVER_FORWARD_HEADERS_STRATEGY=framework

# Lazım olsa CORS artırın (default application.yml-də premiumreklam.shop var)
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://premiumreklam.shop,https://*.premiumreklam.shop
