{
  "version": 2,
  "name": "premium-reklam",
  "framework": "nextjs",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://premiumreklambaku.vercel.app/api",
    "NEXT_PUBLIC_URL": "https://premiumreklambaku.shop"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.premiumreklambaku.shop"
        }
      ],
      "destination": "https://premiumreklambaku.shop/:path*",
      "permanent": true
    }
  ]
}
